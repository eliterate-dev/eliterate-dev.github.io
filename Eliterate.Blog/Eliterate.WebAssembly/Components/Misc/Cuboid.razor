<div class="cuboid" style="@_size @_position @_color @_rotation">
    <div class="cuboid-bottom">
        <div class="cuboid-top">
            <div class="cuboid-label">
                @ChildContent
            </div>
        </div>
    </div>
</div>

@code {
    private string _size => $"--x:{X}px;--y:{Y}px;--z:{Z}px;";
    private string _position => $"--move-x:{MoveX}px;--move-y:{MoveY}px;--move-z:{MoveZ}px;";
    private string _rotation => $"--rotate-x:{RotateX}deg;--rotate-y:{RotateY}deg;--rotate-z:{RotateZ}deg;";
    private string _color => $"--color:hsl({Math.Clamp(Hue, 0, 360)},{Math.Clamp(Saturation, 0, 100)}%,{Math.Clamp(Lightness, 0, 100)}%);";

    [Parameter]
    public double X { get; set; } = 100;
    [Parameter]
    public double Y { get; set; } = 100;
    [Parameter]
    public double Z { get; set; } = 100;
    [Parameter]
    public double MoveX { get; set; }
    [Parameter]
    public double MoveY { get; set; }
    [Parameter]
    public double MoveZ { get; set; }
    [Parameter]
    public double RotateX { get; set; }
    [Parameter]
    public double RotateY { get; set; }
    [Parameter]
    public double RotateZ { get; set; }
    [Parameter]
    public int Hue { get; set; } = 14;
    [Parameter]
    public int Saturation { get; set; } = 100;
    [Parameter]
    public int Lightness { get; set; } = 50;
    [Parameter]
    public RenderFragment? ChildContent { get; set; }
}