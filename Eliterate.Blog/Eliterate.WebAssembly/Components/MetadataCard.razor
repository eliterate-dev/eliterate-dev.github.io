@inject NavigationManager NavigationManager

@if (Model is null)
{
    
}
else
{
    <div class="card" style="rotate:@(rotate/10m)deg;">
        <div class="card-header">
            <div class="grid-container-dash-dot">
                <h2 class="card-title"><a @onclick="GoToPost" tabindex="0" role="heading">@Model.Title</a></h2>
                <Date Model="Model" Replace="true"></Date>
            </div>
            <Sticker Emoji="@Model.StickerEmoji" Top="3" Right="2" Rotate="@(rotate)" Scale="2"></Sticker>
        </div>
        <div class="card-body">
            <div class="card-text" tabindex="0" role="document">
                @Model.Description
            </div>
        </div>
        <div class="card-footer">
            <div class="card-tags">
                @foreach (var tag in Model.Tags)
                {
                    if (string.IsNullOrWhiteSpace(tag))
                        continue;
                    <Tag Name="@tag" Classes="card-tag" Rotate="@(tag.GetRotationFromString(4))"></Tag>
                }
            </div>
            <ReadTime EstimatedReadTimeInMinutes="@Model.EstimatedReadTimeInMinutes"></ReadTime>
        </div>
    </div>
}

@code {
    [Parameter]
    public PostMetadata? Model { get; set; }
    private decimal rotate => Model?.Title.GetRotationFromString(20) ?? 0;

    void GoToPost()
    {
        NavigationManager.NavigateTo($"posts/{Model?.Id}");
    }
}
