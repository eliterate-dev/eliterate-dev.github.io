            <p class="center-text">@(Model?.Emoji ?? Codespirals.CardGames.Poker.PokerConstants.CARDBACKEMOJI)</p>
        </div>
    </div>
</PlayingCard>

@code {
    [Parameter]
    public Codespirals.CardGames.Poker.PokerCard? Model { get; set; }
}
