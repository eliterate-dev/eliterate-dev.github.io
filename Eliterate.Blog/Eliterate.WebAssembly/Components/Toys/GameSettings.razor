<div class="misc-container">
    <div class="game-settings-container">
        @ChildContent
    </div>

    @if (!string.IsNullOrWhiteSpace(RepoLink))
    {
        <div class="repo-link-card">
            <FlashCard Rotation="1.5m">
                <div class="card-header">
                    <h4 class="card-title">The Code</h4>
                </div>
                <div class="card-text">
                    <p>This game is open source. That means the code for this game is freely available for anyone to copy and play with as they wish! Simply click on the GitHub link below.</p>
                </div>
                <div class="card-footer">
                    <div class="card-tags">
                        <Tag Name="GitHub" Classes="card-tag" Link="@RepoLink" Color="#0FBF3E" Rotate="-2"></Tag>
                    </div>
                </div>
                <Sticker Bottom="1" Right="1" Text="📁" Scale="3" Rotate="-5"></Sticker>
            </FlashCard>
        </div>
    }
</div>

@code {
    [Parameter]
    public RenderFragment? ChildContent { get; set; }
    [Parameter]
    public string RepoLink { get; set; } = string.Empty;
}
