@using Codespirals.CardGames.FlipSeven;

@if (Model is null)
{
    <div class="playing-card" style="@_size">
        @Codespirals.CardGames.Poker.PokerConstants.CARDBACKEMOJI
    </div>
}
else
{
    <div class="playing-card" alt="@Model.Name" style="@_size">
        <div class="card-text" style="@_diagonalText">
            @Model.Name
        </div>
    </div>
}

@code {
    [Parameter]
    public Codespirals.CardGames.FlipSeven.FlipSevenCard? Model { get; set; }
    [Parameter]
    public int Scale { get; set; } = 1;

    private string _size => $"font-size:{Scale}rem;";
    private string _diagonalText => Model?.CardType is CardType.Freeze or CardType.SecondChance or CardType.Flip ? $"display: inline-block; transform: rotate(45deg);" : string.Empty;
}