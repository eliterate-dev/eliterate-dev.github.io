@using Eliterate.WebAssembly.Components.Generic.Inputs
@using QRCoder

@page "/tools/qr"
@page "/tools/qr/{urlToEncode?}"

<PageTitle>Eliterate - Tools - QR</PageTitle>

<div class="url-type-tags">
    @foreach (var item in Enum.GetValues(typeof(QRType)).Cast<QRType>())
    {
        <div @onclick="(x => SetQrType(item))">@item</div>
    }
</div>

<div class="fill">
    <Paper>
        <div class="qr-data-form">
            @switch (_selectedQRType)
            {
                case QRType.Url:
                    <InputWithLabel 
                        Label="Url to encode"
                        Description="The most common type of QR codes: A simple representation of an internet URL (a link).
                            Basically all QR readers are programmed to read these and open a tab in your default browser bringing you directly to the website in the code."
                        Warning="While QR codes are quick and convenient, they are also an easy way to have you open a malicious link.
                        Most QR code readers display the URL before they open your browser.
                        Just like a link you'd recieve in an email, always check the URL and make sure it leads you to a site you feel you can trust.">
                        <InputText @bind-Value="_input"></InputText>
                    </InputWithLabel>
                    break;
                default:
                    break;
            }
            <SelectWithLabel 
                TValue="SafeFileType"
                Value="_selectedSaveFileType"
                Label="Save file type"
                Description="The safe file type. A png is a simple image. It's simple to use, but it can get blurry when you resize it. An svg is a mathematically constructed image. You might not be able to use it everywhere, but you can resize it without worry anywhere you use it."
                Options="_safeFileTypes">
            </SelectWithLabel>
            <SelectWithLabel
                Value="_selectedECC"
                Label="ECC"
                Description="The Error Correction Code (ECC) of a QR code describes how much of a QR code is redundant data.
                    That means, with a higher ECC level, there is intentional duplication of data in a QR code.
                    Thanks to this error correction data, a high ECC QR code can be partially obscured and still be read by a QR reader.
                    When you see QR codes that have a company logo in the middle, for example, that is 'obscuring' part of the QR code, thus requiring a higher ECC level."
                Warning="The secondary effect of this is, that because a high ECC QR code encodes more information, they look 'noisier' - more, smaller little black squares than on a QR code with less encoded information or a lower ECC."
                Options="_errorCorrectionLevels">
            </SelectWithLabel>
        </div>
        <div class="qr-generator-controls">
            <button>Generate QR Code</button>
        </div>
    </Paper>
</div>

@if (_generatedQRCodeImage is not null && _generatedQRCodeSvg is not null)
{
    <div class="qr-generator-result">
        @if (_generatedQRCodeImage is not null)
        {
            <img  src="images/photos/Cat_on_tower.jpg"/>
        }
        else
        {
            <svg ></svg>
        }
    </div>
}

@code {
    // resources
    private Dictionary<QRCodeGenerator.ECCLevel, string> _errorCorrectionLevels =
            new Dictionary<QRCodeGenerator.ECCLevel, string>
            {
                {QRCodeGenerator.ECCLevel.L, "Low (7%)"},
                {QRCodeGenerator.ECCLevel.M, "Medium (15%)"},
                {QRCodeGenerator.ECCLevel.Q, "Quartile (25%)"},
                {QRCodeGenerator.ECCLevel.H, "High (30%)"}
            };

    private Dictionary<SafeFileType, string> _safeFileTypes =
            new Dictionary<SafeFileType, string>
            {
                {SafeFileType.png, ".png"},
                {SafeFileType.svg, ".svg"}
            };

    // selections
    private string _input = "";
    private QRType _selectedQRType = QRType.Url;
    private SafeFileType _selectedSaveFileType = SafeFileType.png;
    private QRCodeGenerator.ECCLevel _selectedECC = QRCodeGenerator.ECCLevel.L;

    // results
    private byte[]? _generatedQRCodeImage;
    private string? _generatedQRCodeSvg;

    [Parameter]
    public string? UrlToEncode { get; set; }
    protected override void OnParametersSet() => _input = UrlToEncode ?? "";

    private enum QRType
    {
        Url
    }
    private enum SafeFileType
    {
        png,
        svg
    }

    // functions
    private void SetQrType(QRType type)
        => _selectedQRType = type;

    private void GenerateCode()
    {
        var generator = new QRCodeGenerator();
        var payload = Console.ReadLine() ?? throw new Exception("No url set.");
        QRCodeData data = generator.CreateQrCode(payload, QRCodeGenerator.ECCLevel.H, forceUtf8: true);
    }

    private void SaveAsPng(string saveFilePath, string name, QRCodeData data)
    {
        // PNG bytes (no System.Drawing required)
        var pngQr = new PngByteQRCode(data);
        _generatedQRCodeImage = pngQr.GetGraphic(pixelsPerModule: 10); // scale

    }

    private void SaveAsSvg(string saveFilePath, string name, QRCodeData data)
    {
        var svgQr = new SvgQRCode(data);
        _generatedQRCodeSvg = svgQr.GetGraphic(pixelsPerModule: 10);
    }
}
