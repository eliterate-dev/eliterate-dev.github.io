@page "/posts"
@inject IContentService ContentService

<PageTitle>Eliterate - Posts</PageTitle>

@foreach (var post in Posts)
{
    <MetadataCard Model="post" ZIndex="PostCount--"></MetadataCard>
}

@code
{
    public IEnumerable<PostMetadata> Posts { get; set; } = [];
    public int PostCount { get; set; }
    protected override async Task OnInitializedAsync()
    {
        Posts = await ContentService.GetMetadata();
        PostCount = Posts.Count(p => p.ShowInList);
    }
}