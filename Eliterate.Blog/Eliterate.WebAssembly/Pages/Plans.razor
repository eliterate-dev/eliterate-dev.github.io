@inject IContentService ContentService
@page "/plans"
<PageTitle>Eliterate - Plans & Ideas</PageTitle>

<div class="brick-wall">
    <div class="corkboard">
        @foreach (var item in _ideas)
        {
            <Paper Model="item"></Paper>
        }
    </div>
</div>

@code {
    private IEnumerable<FutureIdea> _ideas = [];

    protected override async Task OnInitializedAsync()
    {
        _ideas = [.. await ContentService.GetPlans()];
    }
}
