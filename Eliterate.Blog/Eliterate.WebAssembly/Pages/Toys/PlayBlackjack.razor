@using Codespirals.CardGames.Poker
@using Codespirals.CardGames.Poker.BlackJack
@using Eliterate.WebAssembly.Components.Toys
@page "/toys/blackjack"

<PageTitle>Eliterate - Blackjack</PageTitle>

<h3>Play Blackjack</h3>

<div class="blackjack-game">
    <div class="blackjack-container">
        <div class="dealer-container">
            <ul>
                <li>Dealer</li>
                <li>Value of Cards: @_game.Dealer.HandValue</li>
            </ul>
            <div class="playing-card-container">
                @foreach (var card in _game.Dealer.Hand)
                {
                    <PlayingCard Model="card" Scale="8"></PlayingCard>
                }
            </div>
        </div>
        <div class="player-container">
            <h4 class="prompt">@_prompt</h4>
            <div class="playing-card-container">
                @foreach (var card in _currentOrFirstPlayer.Hand)
                {
                    <PlayingCard Model="card" Scale="8"></PlayingCard>
                }
            </div>
            <ul>
                <li>Current Player: @_currentOrFirstPlayer.Name</li>
                <li>Value of Cards: @_currentOrFirstPlayer.HandValue</li>
                <li>Cash: @_currentOrFirstPlayer.Cash</li>
            </ul>
        </div>
    </div>
    <div>
        <div class="player-overview">
            <h4>Current buy in: @_game.BuyIn</h4>
            <h4>Player overview:</h4>
            <ul>
                @foreach (var player in _game.Players)
                {
                    <li class="overview-player @(_game.GetCurrentPlayer() == player ? "active" : "")">
                        <div>
                            @player.Name
                        </div>
                        <div class="overview-cards">
                            @foreach (var card in player.Hand)
                            {
                                <PlayingCard Model="card" Scale="1"></PlayingCard>
                            }
                        </div>
                    </li>
                }
            </ul>
        </div>
        <div class="round-feed">
            <h4>Round @_game.CurrentRound feed:</h4>
            <pre class="feedback">@_feedback</pre>
        </div>
    </div>
</div>

<div class="game-controls">
    <button @onclick="Stand" disabled="@(!_game.RoundActive || _game.GameOver)">Stand</button>
    <button @onclick="Hit" disabled="@(!_game.RoundActive || _game.GameOver)">Hit Me</button>

    <button class="right" @onclick="StartNextRound" disabled="@(_game.RoundActive || _game.GameOver)">Start Next Round</button>
</div>

<div class="game-settings">
    <label>Number of players</label><InputNumber @bind-value="_numberOfPlayers" DisplayName="Number of players" />
    <label>Winning Score</label><InputNumber @bind-value="_winningScore" DisplayName="Winning Score" />
    <label>Starting Buy-in</label><InputNumber @bind-value="_minBet" DisplayName="Starting Buy-in" />
    <label>Starting Cash</label><InputNumber @bind-value="_startingCash" DisplayName="Starting Cash" />
    <label>Auto increase buy in after round</label><InputNumber @bind-value="_autoIncreaseBuyInAfterRound" DisplayName="Increase buy in after round" />
    <button @onclick="Restart">Apply and Restart</button>
</div>

@code {
    private BlackJackGame _game = BlackJackGame.SetUp(1, 1, 21, 100, 1);
    private BlackJackPlayer _currentPlayer => _game.GetCurrentPlayer();
    private BlackJackPlayer _currentOrFirstPlayer => _currentPlayer == _game.Dealer ? _game.Players[1] : _currentPlayer;
    private string _prompt = "";
    private string _feedback = "";

    private int _numberOfPlayers = 1;
    private int _minBet = 1;
    private int _winningScore = 21;
    private int _startingCash = 100;
    private int _autoIncreaseBuyInAfterRound = 1;

    protected override async Task OnInitializedAsync()
    {
        Restart();
    }

    private void Restart()
    {
        _game = BlackJackGame.SetUp(_numberOfPlayers, _minBet, _winningScore, _startingCash, _autoIncreaseBuyInAfterRound);
        _prompt = "Start the round!";
        _feedback = $"Starting Round {_game.CurrentRound}";
        _game.StartRound();
        MoveToNextPlayer();
    }

    private void StartNextRound()
    {
        _game.StartRound();
        MoveToNextPlayer();
        _prompt = $"{_currentPlayer} choose an action!";
        _feedback = $"Starting Round {_game.CurrentRound}";
    }

    private void Stand()
    {
        _game.Stand(_currentPlayer);
        _feedback += $"\n{_currentPlayer.Name} is standing on {_currentPlayer.HandValue}!";
        EvaluateHand();
    }
    private void Hit()
    {
        var newCard = _game.Hit(_currentPlayer);
        _feedback += $"\n{_currentPlayer.Name} drew {newCard.Name}!";
        EvaluateHand();
    }

    private void MoveToNextPlayer()
    {
        _game.MoveToNextPlayer();

        if (_currentPlayer == _game.Dealer)
        {
            PlayDealer();
        }
        else
        {
            _prompt = $"{_currentPlayer.Name} choose an action!";
        }
    }

    private void PlayDealer()
    {
        if (_game.Dealer.HandValue <= 17)
        {
            Hit();
            if (_game.Dealer.HandValue > _game.WinningScore)
            {
                EndRound();
            }
        }
        else if (!_game.Dealer.IsOutForRound)
        {
            Stand();
        }
    }

    private void EvaluateHand()
    {
        if (_currentPlayer.HandValue > _game.WinningScore)
        {
            _currentPlayer.Bust();
            if (_currentPlayer == _game.Dealer)
            {
                _feedback += $"\nOof. The {_currentPlayer.Name} went over {_game.WinningScore}!";
            }
            else
            {
                _feedback += $"\nOh no... {_currentPlayer.Name} got busted!";
            }
        }

        if (_game.RoundActive)
        {
            MoveToNextPlayer();
        }
        else
        {
            EndRound();
        }
    }

    private void EndRound()
    {
        foreach (var player in _game.Players.Except([_game.Dealer]))
        {
            if (player.HandValue == _game.WinningScore && player.Hand.Count == 2)
            {
                _feedback += $"\n{player.Name} got a Blackjack! +{_game.BuyIn * 3}";
                player.AddWinnings(_game.BuyIn * 3);
                continue;
            }
            var dealerBusted = _game.Dealer.HandValue > _game.WinningScore;
            var playerBusted = player.HandValue > _game.WinningScore;
            // points
            if ((dealerBusted && !playerBusted)
                || (!dealerBusted && !playerBusted && player.HandValue > _game.Dealer.HandValue))
            {
                _feedback += $"\n{player.Name} won! +{_game.BuyIn * 2}";
                player.AddWinnings(_game.BuyIn * 2);
            }
            else if (!dealerBusted && player.HandValue == _game.Dealer.HandValue)
            {
                _feedback += $"\n{player.Name} drew with the dealer! +{_game.BuyIn}";
                player.AddWinnings(_game.BuyIn);
            }
            else
            {
                _feedback += $"\n{player.Name} lost!";
            }
        }

        _game.EndRound();
        if (_autoIncreaseBuyInAfterRound > 0)
            _feedback += $"\nThe stakes have risen by {_autoIncreaseBuyInAfterRound}!";

        if (_game.GameOver)
        {
            foreach (var player in _game.Players)
            {
                player.DiscardAll();
            }
            _feedback = $"GAME OVER!";
        }
    }
}
