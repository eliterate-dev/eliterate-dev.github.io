@page "/posts/{id}"
@inject IContentService ContentService

<PageTitle>Eliterate - @(Model?.Metadata.Title ?? "Empty page")</PageTitle>

<PostPage Model="Model"></PostPage>

@code {
    [Parameter]
    public string Id { get; set; } = "";
    public BlogPost? Model { get; set; }

    protected override async Task OnInitializedAsync()
    {
        Model = await ContentService.GetPost(Id);
    }
}
