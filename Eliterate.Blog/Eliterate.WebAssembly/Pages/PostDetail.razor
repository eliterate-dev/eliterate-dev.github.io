@page "/posts/{id:int}"
@inject IContentService ContentService

<PageTitle>Eliterate - @Model.Metadata.PostNumber - @Model.Metadata.Title</PageTitle>

<PostPage Model="Model"></PostPage>

@code {
    [Parameter]
    public int Id { get; set; }
    public BlogPost Model { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        Model = await ContentService.GetPost(Id) ?? new();
    }
}
