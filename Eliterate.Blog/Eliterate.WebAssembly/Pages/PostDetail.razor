@page "/posts/{id}"
@inject IContentService ContentService

<PageTitle>Eliterate - @Model.Metadata.Title</PageTitle>

<PostPage Model="Model"></PostPage>

@code {
    [Parameter]
    public string Id { get; set; } = "";
    public BlogPost Model { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        Model = await ContentService.GetPost(Id) ?? new();
    }
}
