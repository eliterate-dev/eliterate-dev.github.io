@page "/credit"
@inject IContentService ContentService

<PageTitle>Eliterate - Credit</PageTitle>

<ClosedBook Back="true">
    <h2 class="center-text">Credit</h2>
    <table>
        @foreach (var item in credits)
        {
            <tr>
                <td>@(item.Description ?? "Thanks")</td>
                <td><a href="@item.Link" target="_blank" tabindex="0">@item.Name ↗</a></td>
            </tr>
        }
    </table>

    <div class="qr-code"><img src="/images/pictures/eliterate_qr.png" srcset="/images/pictures/eliterate.svg" alt="▣" /></div>
    <div class="copyright">&copy @DateTime.UtcNow.Year Eliterate</div>

    <Sticker Text="📱" Right="2" Top="1" Scale="3" Rotate="20"></Sticker>
    <Sticker Text="🪫" Left="5" Bottom="1.75m" Scale="3" Rotate="86"></Sticker>
</ClosedBook>

@code
{
    private IEnumerable<LinkItem> credits = [];

    protected override async Task OnInitializedAsync()
    {
        credits = await ContentService.GetCredits();
    }
}