@page "/"
@inject IContentService ContentService

<PageTitle>Eliterate - @About.Metadata.PostNumber - @About.Metadata.Title</PageTitle>

<Post Model="About"></Post>

@code {
    public BlogPost About { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        About = await ContentService.GetPost(0) ?? new();
    }
}