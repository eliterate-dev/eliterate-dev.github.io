@page "/components"
@using Eliterate.WebAssembly.Components.Generic

<PageTitle>Components</PageTitle>

<div style="position:absolute;top:0.25rem;right:2rem;">
    <InputSelect @bind-Value="_selected">
        @foreach (var item in Enum.GetValues(typeof(Component)).Cast<Component>())
        {
            <option value="@item">@item</option>
        }
    </InputSelect>
</div>
<div class="fill component-showcase" style="margin:2rem;border:10px inset dimgrey;background-color:darkgrey;overflow-y:scroll;">
    @switch (_selected)
    {
        case Component.Cuboid:
            <div style="position:absolute;top:0;right:0;z-index:1;display:grid;grid-template-columns:max-content max-content max-content max-content;">
                <label>X</label> <InputNumber @bind-value="_x" />
                <label>Rotate X</label> <InputNumber @bind-value="_rotateX" />
                <label>Y</label> <InputNumber @bind-value="_y" />
                <label>Rotate Y</label> <InputNumber @bind-value="_rotateY" />
                <label>Z</label> <InputNumber @bind-value="_z" />
                <label>Rotate Z</label> <InputNumber @bind-value="_rotateZ" />
            </div>
            <div class="fill center-content">
                <Cuboid X="_x" Y="_y" Z="_z" RotateX="_rotateX" RotateY="_rotateY" RotateZ="_rotateZ" SideLabel="Side Text"></Cuboid>
            </div>
            break;
        case Component.Book:
            <div style="position:absolute;top:0;right:0;z-index:1;display:grid;grid-template-columns:max-content max-content max-content max-content;">
                <label>X</label> <InputNumber @bind-value="_x" />
                <label>Rotate X</label> <InputNumber @bind-value="_rotateX" />
                <label>Y</label> <InputNumber @bind-value="_y" />
                <label>Rotate Y</label> <InputNumber @bind-value="_rotateY" />
                <label>Z</label> <InputNumber @bind-value="_z" />
                <label>Rotate Z</label> <InputNumber @bind-value="_rotateZ" />
            </div>
            <div class="fill center-content">
                <Book X="_x" Y="_y" Z="_z" RotateX="_rotateX" RotateY="_rotateY" RotateZ="_rotateZ">
                    <div class="fill">
                        <h3 style="text-align:center;margin-top:10%;color:white;">I can't read</h3>
                    </div>
                </Book>
            </div>
            break;
        case Component.RotatingDisplay:
            <div style="position:absolute;top:0;right:0;z-index:1;display:grid;grid-template-columns:max-content max-content max-content max-content;">
                <label>X</label> <InputNumber @bind-value="_x" />
                <label>Rotate X</label> <InputNumber @bind-value="_rotateX" />
                <label>Y</label> <InputNumber @bind-value="_y" />
                <label>Rotate Y</label> <InputNumber @bind-value="_rotateY" />
                <label>Z</label> <InputNumber @bind-value="_z" />
                <label>Rotate Z</label> <InputNumber @bind-value="_rotateZ" />
            </div>
            <RotatingDisplay>
                <Cuboid X="_x" Y="_y" Z="_z" RotateX="_rotateX" RotateY="_rotateY" RotateZ="_rotateZ" SideLabel="Side Text"></Cuboid>
            </RotatingDisplay>
            break;
        case Component.RadialText:
            <div style="position:absolute;top:0;right:0;z-index:1;display:grid;grid-template-columns:max-content 1fr;">
                <label>Text</label> <InputText DisplayName="Text" @bind-value="_text" />
                <label>Font Size</label><InputNumber DisplayName="Font Size" @bind-value="_fontSize"></InputNumber>
                <label>Size</label><InputNumber DisplayName="Size" @bind-value="_size"></InputNumber>
                <label>Angle</label><InputNumber DisplayName="Angle" @bind-value="_angle"></InputNumber>
            </div>
            <div class="fill center-content">
                <RadialText Text="@_text" FontSize="_fontSize" Size="_size" Angle="_angle">
                    <img src="images/photos/Cat_on_tower.jpg" />
                </RadialText>
            </div>
            break;
        case Component.InputWithLabel:
            <div style="display:grid;grid-template-columns:max-content 1fr;">
                <label>Description</label><InputTextArea @bind-Value="_description"></InputTextArea>
                <label>Warning</label><InputTextArea @bind-Value="_warning"></InputTextArea>
            </div>
            <InputWithLabel Label="Test Text"
                            Description="@_description"
                            Warning="@_warning">
                <InputText @bind-Value="_textInput"></InputText>
            </InputWithLabel>
            <InputWithLabel Label="Test Number"
                            Description="@_description"
                            Warning="@_warning">
                <InputNumber @bind-Value="_numberInput"></InputNumber>
            </InputWithLabel>
            <InputWithLabel Label="Test Checkbox"
                            Description="@_description"
                            Warning="@_warning">
                <InputCheckbox @bind-Value="_boolInput"></InputCheckbox>
            </InputWithLabel>
            <InputWithLabel Label="Test Radio"
                            Description="@_description"
                            Warning="@_warning">
                <InputRadioGroup @bind-Value="_radioInput">
                    @foreach (var item in _selectOptions)
                    {
                        <label>
                            <InputRadio Value="item"></InputRadio>
                            @item
                        </label>
                    }
                </InputRadioGroup>
            </InputWithLabel>
            <InputWithLabel Label="Test Date"
                            Description="@_description"
                            Warning="@_warning">
                <InputDate @bind-Value="_dateInput"></InputDate>
            </InputWithLabel>
            <InputWithLabel Label="Test Select"
                            Description="@_description"
                            Warning="@_warning">
                <InputSelect @bind-Value="_selectInput">
                    @foreach (var item in _selectOptions)
                    {
                        <option value="@item">@item</option>
                    }
                </InputSelect>
            </InputWithLabel>
            break;
        default:
            <div class="fill center-content">
                <p>Nothing selected</p>
            </div>
            break;
    }
</div>


@code {
    private Component _selected;

    // cuboid controls
    private int _x = 100;
    private int _y = 100;
    private int _z = 100;
    private int _rotateX = 60;
    private int _rotateY = 0;
    private int _rotateZ = 45;

    // Radial text controls
    private string _text = "Testing Radial Text";
    private int _fontSize = 16;
    private int _size = 200;
    private int _angle = 180;

    // Input with labels
    private string _description = "This is a description of this field. It's long and winding and almost nobody actually reads it, but hey maybe it helps someone.";
    private string _warning = "This is an additional warning about this field. It should be short and snappy.";
    private string _textInput = "";
    private int _numberInput = 1;
    private bool _boolInput;
    private DateTime _dateInput = DateTime.UtcNow;
    private string _selectInput = "A";
    private string _radioInput = "A";

    private string[] _selectOptions = ["A", "B", "C"];

    private enum Component
    {
        None,
        Cuboid,
        Book,
        RotatingDisplay,
        RadialText,
        InputWithLabel
    }
}
